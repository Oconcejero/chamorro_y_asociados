---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import "../styles/main.css";

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Chamorro & Asociados">
	<Header />

	<main class="home-hero">
		<div class="hero-content">
			<img
				src={`${baseUrl}/ICON_HOME.svg`}
				alt="Logo Chamorro & Asociados"
				class="hero-logo"
			/>

			<h1 class="hero-title">Chamorro & Asociados</h1>

			<p class="hero-slogan">
				"Vale más conseguir un <span class="highlight">BUEN ACUERDO</span><br />
				que porfiar en el <span class="highlight">MEJOR PLEITO</span>"
			</p>
		</div>
	</main>
</Layout>
