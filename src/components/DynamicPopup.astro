          </ul>
    `,
    color: "#ff007f",
  },
  default: {
    title: "¿En qué podemos ayudarte?",
    text: "Nuestro equipo está listo para asesorarte en tu caso legal.",
    color: "#1a1a1a",
  },
};

const cleanPath =
  pathname.endsWith("/") && pathname !== `${baseUrl}/`
    ? pathname.slice(0, -1)
    : pathname;
const content = contentMap[cleanPath] || contentMap["default"];
---

<div class="button-center-container">
  <button
    id="open-popup"
    class="trigger-btn"
    style={`--btn-color: ${content.color}`}
  >
    ¿Qué podemos hacer por ti?
  </button>
</div>

<div id="popup-overlay" class="overlay">
  <div class="popup-card">
    <button id="close-popup" class="close-btn">&times;</button>
    <h2 style={`color: ${content.color}`}>{content.title}</h2>
    <div class="popup-text" set:html={content.text} />
  </div>
</div>

<script>
  const openBtn = document.getElementById("open-popup") as HTMLButtonElement;
  const closeBtn = document.getElementById("close-popup") as HTMLButtonElement;
  const overlay = document.getElementById("popup-overlay") as HTMLElement;

  openBtn?.addEventListener("click", () => {
    overlay?.classList.add("active");
  });

  closeBtn?.addEventListener("click", () => {
    overlay?.classList.remove("active");
  });

  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) {
      overlay?.classList.remove("active");
    }
  });
</script>
